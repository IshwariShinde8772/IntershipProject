PORT=5000
NODE_ENV=development
APP_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kbtcoe_placement_tracker
JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_RESET_SECRET=replace_with_long_random_reset_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
REFRESH_COOKIE_NAME=refreshToken
# Leave SendGrid blank if using Gmail SMTP
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
# Gmail SMTP (use an App Password, not your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords (requires 2FA)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
MAIL_FROM_EMAIL=your_gmail@gmail.com
MAIL_FROM_NAME=KBTCOE Placement Portal
CLOUDINARY_CLOUD_NAME=replace_with_cloud_name
CLOUDINARY_API_KEY=replace_with_api_key
CLOUDINARY_API_SECRET=replace_with_api_secret
